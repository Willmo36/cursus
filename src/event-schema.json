{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://react-workflow.dev/schema/v1/workflow-trace.json",
	"title": "WorkflowTrace",
	"description": "Envelope wrapping a workflow's event log with version metadata.",
	"type": "object",
	"required": [
		"schemaVersion",
		"libraryVersion",
		"workflowId",
		"events"
	],
	"additionalProperties": false,
	"properties": {
		"schemaVersion": {
			"type": "integer",
			"description": "Monotonic schema version, bumped when event shapes change."
		},
		"libraryVersion": {
			"type": "string",
			"description": "npm package version that produced the events."
		},
		"workflowId": {
			"type": "string"
		},
		"events": {
			"type": "array",
			"items": {
				"oneOf": [
					{
						"$ref": "#/$defs/WorkflowStartedEvent"
					},
					{
						"$ref": "#/$defs/WorkflowCompletedEvent"
					},
					{
						"$ref": "#/$defs/WorkflowFailedEvent"
					},
					{
						"$ref": "#/$defs/WorkflowCancelledEvent"
					},
					{
						"$ref": "#/$defs/ActivityScheduledEvent"
					},
					{
						"$ref": "#/$defs/ActivityCompletedEvent"
					},
					{
						"$ref": "#/$defs/ActivityFailedEvent"
					},
					{
						"$ref": "#/$defs/TimerStartedEvent"
					},
					{
						"$ref": "#/$defs/TimerFiredEvent"
					},
					{
						"$ref": "#/$defs/ChildStartedEvent"
					},
					{
						"$ref": "#/$defs/ChildCompletedEvent"
					},
					{
						"$ref": "#/$defs/ChildFailedEvent"
					},
					{
						"$ref": "#/$defs/WorkflowPublishedEvent"
					},
					{
						"$ref": "#/$defs/AllStartedEvent"
					},
					{
						"$ref": "#/$defs/AllCompletedEvent"
					},
					{
						"$ref": "#/$defs/RaceStartedEvent"
					},
					{
						"$ref": "#/$defs/RaceCompletedEvent"
					},
					{
						"$ref": "#/$defs/ReceiveResolvedEvent"
					},
					{
						"$ref": "#/$defs/ReadResolvedEvent"
					},
					{
						"$ref": "#/$defs/LoopStartedEvent"
					},
					{
						"$ref": "#/$defs/LoopCompletedEvent"
					}
				]
			}
		}
	},
	"$defs": {
		"WorkflowStartedEvent": {
			"type": "object",
			"required": [
				"type",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "workflow_started"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"WorkflowCompletedEvent": {
			"type": "object",
			"required": [
				"type",
				"result",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "workflow_completed"
				},
				"result": {},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"WorkflowFailedEvent": {
			"type": "object",
			"required": [
				"type",
				"error",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "workflow_failed"
				},
				"error": {
					"type": "string"
				},
				"stack": {
					"type": "string"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"WorkflowCancelledEvent": {
			"type": "object",
			"required": [
				"type",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "workflow_cancelled"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"ActivityScheduledEvent": {
			"type": "object",
			"required": [
				"type",
				"name",
				"seq",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "activity_scheduled"
				},
				"name": {
					"type": "string"
				},
				"seq": {
					"type": "integer"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"ActivityCompletedEvent": {
			"type": "object",
			"required": [
				"type",
				"seq",
				"result",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "activity_completed"
				},
				"seq": {
					"type": "integer"
				},
				"result": {},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"ActivityFailedEvent": {
			"type": "object",
			"required": [
				"type",
				"seq",
				"error",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "activity_failed"
				},
				"seq": {
					"type": "integer"
				},
				"error": {
					"type": "string"
				},
				"stack": {
					"type": "string"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"TimerStartedEvent": {
			"type": "object",
			"required": [
				"type",
				"seq",
				"durationMs",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "timer_started"
				},
				"seq": {
					"type": "integer"
				},
				"durationMs": {
					"type": "number"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"TimerFiredEvent": {
			"type": "object",
			"required": [
				"type",
				"seq",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "timer_fired"
				},
				"seq": {
					"type": "integer"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"ChildStartedEvent": {
			"type": "object",
			"required": [
				"type",
				"name",
				"workflowId",
				"seq",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "child_started"
				},
				"name": {
					"type": "string"
				},
				"workflowId": {
					"type": "string"
				},
				"seq": {
					"type": "integer"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"ChildCompletedEvent": {
			"type": "object",
			"required": [
				"type",
				"workflowId",
				"seq",
				"result",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "child_completed"
				},
				"workflowId": {
					"type": "string"
				},
				"seq": {
					"type": "integer"
				},
				"result": {},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"ChildFailedEvent": {
			"type": "object",
			"required": [
				"type",
				"workflowId",
				"seq",
				"error",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "child_failed"
				},
				"workflowId": {
					"type": "string"
				},
				"seq": {
					"type": "integer"
				},
				"error": {
					"type": "string"
				},
				"stack": {
					"type": "string"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"WorkflowPublishedEvent": {
			"type": "object",
			"required": [
				"type",
				"value",
				"seq",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "workflow_published"
				},
				"value": {},
				"seq": {
					"type": "integer"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"AllStartedEvent": {
			"type": "object",
			"required": [
				"type",
				"seq",
				"items",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "all_started"
				},
				"seq": {
					"type": "integer"
				},
				"items": {
					"type": "array",
					"items": {
						"type": "object",
						"required": [
							"type"
						],
						"properties": {
							"type": {
								"type": "string"
							}
						}
					}
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"AllCompletedEvent": {
			"type": "object",
			"required": [
				"type",
				"seq",
				"results",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "all_completed"
				},
				"seq": {
					"type": "integer"
				},
				"results": {
					"type": "array"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"RaceStartedEvent": {
			"type": "object",
			"required": [
				"type",
				"seq",
				"items",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "race_started"
				},
				"seq": {
					"type": "integer"
				},
				"items": {
					"type": "array",
					"items": {
						"type": "object",
						"required": [
							"type"
						],
						"properties": {
							"type": {
								"type": "string"
							}
						}
					}
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"RaceCompletedEvent": {
			"type": "object",
			"required": [
				"type",
				"seq",
				"winner",
				"value",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "race_completed"
				},
				"seq": {
					"type": "integer"
				},
				"winner": {
					"type": "integer"
				},
				"value": {},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"ReceiveResolvedEvent": {
			"type": "object",
			"required": [
				"type",
				"label",
				"value",
				"seq",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "receive_resolved"
				},
				"label": {
					"type": "string"
				},
				"value": {},
				"seq": {
					"type": "integer"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"ReadResolvedEvent": {
			"type": "object",
			"required": [
				"type",
				"label",
				"seq",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "read_resolved"
				},
				"label": {
					"type": "string"
				},
				"seq": {
					"type": "integer"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"LoopStartedEvent": {
			"type": "object",
			"required": [
				"type",
				"seq",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "loop_started"
				},
				"seq": {
					"type": "integer"
				},
				"timestamp": {
					"type": "number"
				}
			}
		},
		"LoopCompletedEvent": {
			"type": "object",
			"required": [
				"type",
				"seq",
				"value",
				"timestamp"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"const": "loop_completed"
				},
				"seq": {
					"type": "integer"
				},
				"value": {},
				"timestamp": {
					"type": "number"
				}
			}
		}
	}
}
